      "source": [
        "# Edge Detection using Gradient Magnitude\n",
        "\n",
        "import math\n",
        "\n",
        "Gx = 5\n",
        "Gy = 12\n",
        "\n",
        "edge = math.sqrt(Gx**2 + Gy**2)\n",
        "\n",
        "print(\"Edge Strength =\", int(edge))"
      ]
    }
  ]
